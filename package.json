{
  "name": "prompt-hub",
  "version": "0.1.0",
  "description": "Local-first workspace for building, organizing, reusing, importing and exporting structured prompts, skills, roles and agents.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "andersseen",
    "email": "andriipap01@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andersseen/prompt-hub.git"
  },
  "bugs": {
    "url": "https://github.com/andersseen/prompt-hub/issues"
  },
  "homepage": "https://github.com/andersseen/prompt-hub#readme",
  "keywords": [
    "analogjs",
    "angular",
    "agents",
    "dexie",
    "indexeddb",
    "local-first",
    "prompt-engineering",
    "prompts",
    "typescript",
    "volt-ui"
  ],
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "ng": "ng",
    "dev": "vite",
    "start": "pnpm run dev",
    "build": "vite build",
    "watch": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit",
    "lint": "eslint .",
    "e2e": "playwright test",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
    "preview": "node dist/analog/server/index.mjs",
    "deploy": "pnpm run build && wrangler pages deploy dist/client --project-name=prompt-hub",
    "deploy:preview": "pnpm run build && wrangler pages deploy dist/client --project-name=prompt-hub --branch=preview"
  },
  "dependencies": {
    "@analogjs/content": "^2.5.1",
    "@analogjs/router": "^2.5.1",
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@voltui/components": "^0.1.0",
    "angular-movement": "^0.0.2",
    "dexie": "^4.4.2",
    "front-matter": "^4.0.2",
    "h3": "^1.13.0",
    "marked": "^15.0.7",
    "marked-gfm-heading-id": "^4.1.1",
    "marked-highlight": "^2.2.1",
    "marked-mangle": "^1.1.10",
    "postcss": "^8.5.3",
    "prismjs": "^1.29.0",
    "quartz-headless": "^0.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.5.1",
    "@analogjs/vite-plugin-angular": "^2.5.1",
    "@analogjs/vitest-angular": "^2.5.1",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.8.0",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.4.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^22.0.0",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "vite": "$vite",
    "vitest": "$vitest"
  }
}
